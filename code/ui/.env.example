## PicoClaw UI — example environment overrides (Vite)
## Copy to `.env.local` for machine-specific values.

## Weather (Open‑Meteo)
# Precise install coordinates (example: Appio‑Latino, Roma)
VITE_WEATHER_LAT=41.8693
VITE_WEATHER_LON=12.5113
VITE_WEATHER_LABEL="Appio-Latino, Roma"

# Optional: refine with browser Geolocation (requires secure context / localhost)
VITE_WEATHER_USE_GEOLOCATION=false

## Optional: Raspberry backlight control endpoints
# VITE_BACKLIGHT_DIM_URL="http://localhost:8080/backlight/dim"
# VITE_BACKLIGHT_RESTORE_URL="http://localhost:8080/backlight/restore"

## Optional: backend base URL (if not same-origin)
# VITE_BACKEND_BASE="http://127.0.0.1:8787"
# URL backend (senza slash finale). Vuoto = stessa origine (proxy dev su /health).
# VITE_BACKEND_BASE=http://192.168.2.136:8787

# Alba / tramonto mock per tema (HH:mm)
# VITE_SUNRISE=06:30
# VITE_SUNSET=20:30
