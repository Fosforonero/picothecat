# Copia questo file come push-ui.local.env nella stessa cartella deploy/
# (push-ui.local.env non va committato: è in .gitignore)
#
# In Cursor l'agent spesso non eredita la ssh-agent della sessione grafica:
# indicare la chiave privata risolve quasi sempre
# "Permission denied (publickey,password)".
#
# PICOCLAW_SSH_IDENTITY_FILE="${HOME}/.ssh/id_ed25519"
#
# Opzionale: override host (es. alias definito in ~/.ssh/config)
# PICOCLAW_SSH_USER_HOST="matteo@192.168.2.136"
#
# Opzionale: ssh -F (config dedicata, path assoluto)
# PICOCLAW_SSH_CONFIG="${HOME}/.ssh/config"
#
# Opzionale: URL per il check HTTP finale
# PICOCLAW_HTTP_CHECK_URL="http://192.168.2.136:3000/"
